MONGODB_URI=
# Database name (Mongoose uses this even if the URI path is empty or /test — fixes prod using `test`).
MONGODB_DB_NAME=vinayak_academy
PORT=5001
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# Email notifications (nodemailer) — receive a copy when someone submits the enquiry form
# Gmail: use an App Password (Google Account → Security → 2-Step → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# Where to receive enquiry alerts (often the same as SMTP_USER)
NOTIFY_EMAIL=your-email@gmail.com
# Optional: From header (defaults to "Vinayak Academy" <SMTP_USER>)
# SMTP_FROM="Vinayak Academy <your-email@gmail.com>"
