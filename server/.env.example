MONGODB_URI=
# Database name (Mongoose uses this even if the URI path is empty or /test — fixes prod using `test`).
MONGODB_DB_NAME=vinayak_academy
PORT=5001
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# Email notifications via Resend (HTTP API — works everywhere including Render)
# Get your free API key at https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Where to receive enquiry alerts
NOTIFY_EMAIL=your-email@gmail.com
